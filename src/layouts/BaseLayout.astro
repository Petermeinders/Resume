---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  currentPath: string;
  wide?: boolean;
}

const { title, currentPath, wide = false } = Astro.props;
const pageTitle = title === 'Peter Meinders' ? title : `${title} — Peter Meinders`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Resume of Peter Meinders — Full-Stack Sr. Software Engineer" />
    <title>{pageTitle}</title>
    <style is:global define:vars={{ bgImage: `url('${base}images/background.jpg')` }}>
      body {
        background-image: var(--bgImage);
      }
    </style>
  </head>
  <body>
    <Header />
    <Nav currentPath={currentPath} />
    <main class:list={['site-main', wide && 'site-main--wide']}>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Peter Meinders</p>
    </footer>
  </body>
</html>
